<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Viewer">
    <Grid>
        <!-- DX12 渲染面板（最底層） -->
        <SwapChainPanel x:Name="RenderPanel"
                        Loaded="RenderPanel_Loaded"
                        SizeChanged="RenderPanel_SizeChanged"
                        Unloaded="RenderPanel_Unloaded"
                        PointerPressed="RenderPanel_PointerPressed"
                        PointerMoved="RenderPanel_PointerMoved"
                        PointerReleased="RenderPanel_PointerReleased"
                        PointerWheelChanged="RenderPanel_PointerWheelChanged"/>

        <!-- UI 覆蓋層（之後加工具列等） -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="16" IsHitTestVisible="False">
            <TextBlock Text="DX12 Ready ✓"
                       Foreground="White"
                       FontSize="14"
                       x:Name="StatusText"/>

            <TextBlock x:Name="StatsText"
                       Foreground="#FF00FF00"
                       FontSize="13"
                       Margin="0,4,0,0"
                       FontFamily="Consolas" />
        </StackPanel>
        <Button Content="開啟模型" Click="OpenModel_Click"
        VerticalAlignment="Top" HorizontalAlignment="Right"
        Margin="16" />
    </Grid>
</Window>