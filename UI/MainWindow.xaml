<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Viewer">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Hierarchy" Foreground="#CCCCCC" FontWeight="SemiBold" Margin="12,12,12,8" />

                <TreeView x:Name="HierarchyTree" Grid.Row="1" Background="Transparent"
                          ItemInvoked="HierarchyTree_ItemInvoked"
                          RightTapped="HierarchyTree_RightTapped">
                </TreeView>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <SwapChainPanel x:Name="RenderPanel"
                            Loaded="RenderPanel_Loaded"
                            SizeChanged="RenderPanel_SizeChanged"
                            Unloaded="RenderPanel_Unloaded"/>

            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="16" IsHitTestVisible="False">
                <TextBlock Text="DX12 Ready ✓" Foreground="White" FontSize="14" x:Name="StatusText"/>
                <TextBlock x:Name="StatsText" Foreground="#FF00FF00" FontSize="13" Margin="0,4,0,0" FontFamily="Consolas" />
            </StackPanel>

            <Button Content="モデルを開く" Click="OpenModel_Click"
                    VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16" />

            <Border x:Name="LoadingOverlay" Background="#A0000000" Visibility="Collapsed"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressRing IsActive="True" Width="80" Height="80" Foreground="White"/>
                    <TextBlock Text="Loading..." Foreground="White" FontSize="20" FontWeight="Bold"
                               Margin="0,16,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1,0,0,0">
            <StackPanel Margin="12">
                <ToggleSwitch x:Name="RayTracingToggle" 
                  Header="Ray Tracing (DXR)" 
                  OffContent="オフ" OnContent="オン"
                  Toggled="RayTracingToggle_Toggled" 
                  Margin="0,0,0,16"/>
                <TextBlock Text="Inspector" Foreground="#CCCCCC" FontWeight="SemiBold" Margin="0,0,0,16" />

                <TextBlock Text="ノード名" Foreground="#888888" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="NodeNameText" IsReadOnly="True" Background="#2D2D2D" Foreground="White" BorderThickness="0" Margin="0,0,0,16"/>

                <TextBlock Text="Position (座標)" Foreground="#888888" FontSize="12" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="PosXText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="PosYText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Z:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="PosZText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>

                <TextBlock Text="Rotation (Euler 角度)" Foreground="#888888" FontSize="12" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="RotXText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="RotYText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Z:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="RotZText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>

                <TextBlock Text="Scale (拡縮)" Foreground="#888888" FontSize="12" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="ScaleXText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="ScaleYText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Z:" VerticalAlignment="Center" Foreground="#888888"/>
                    <TextBox x:Name="ScaleZText" Grid.Column="1" LostFocus="TransformInput_LostFocus" KeyDown="TransformInput_KeyDown"/>
                </Grid>
                <StackPanel x:Name="LightSettingsPanel" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="Color (RGB 0~1)" Foreground="#888888" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LightRText" Margin="0,0,2,0" LostFocus="LightInput_LostFocus" KeyDown="LightInput_KeyDown"/>
                        <TextBox x:Name="LightGText" Grid.Column="1" Margin="2,0,2,0" LostFocus="LightInput_LostFocus" KeyDown="LightInput_KeyDown"/>
                        <TextBox x:Name="LightBText" Grid.Column="2" Margin="2,0,0,0" LostFocus="LightInput_LostFocus" KeyDown="LightInput_KeyDown"/>
                    </Grid>
                    <TextBlock Text="Intensity" Foreground="#888888" FontSize="12" Margin="0,8,0,4"/>
                    <TextBox x:Name="LightIntensityText" LostFocus="LightInput_LostFocus" KeyDown="LightInput_KeyDown"/>
                    <StackPanel x:Name="ConeAnglePanel">
                        <TextBlock Text="Cone Angle" Foreground="#888888" FontSize="12" Margin="0,8,0,4"/>
                        <TextBox x:Name="LightConeText" LostFocus="LightInput_LostFocus" KeyDown="LightInput_KeyDown"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
